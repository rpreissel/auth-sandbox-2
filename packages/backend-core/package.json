{
  "name": "@auth-sandbox-2/backend-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm exec esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --eval \"console.log('backend-core: no tests')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format:check": "node --eval \"console.log('backend-core: format check skipped')\""
  },
  "dependencies": {
    "@auth-sandbox-2/shared-types": "workspace:*",
    "dotenv": "^17.2.2",
    "pg": "^8.16.3",
    "pino": "^9.9.5",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.2"
  }
}
