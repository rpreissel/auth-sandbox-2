{
  log {
    output file /var/log/caddy/access.json {
      roll_size 10MiB
      roll_keep 5
      roll_keep_for 168h
    }
    format json
  }
}

http://home.localhost:8088 {
  redir https://home.localhost:8443{uri}
}

https://home.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host home.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  root * /srv/home-web
  file_server
}

http://app.localhost:8088 {
  redir https://app.localhost:8443{uri}
}

https://app.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host app.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  handle_path /trace-api/* {
    reverse_proxy trace-api:3001
  }
  handle_path /mock-api/* {
    reverse_proxy mock-api:3002
  }
  root * /srv/app-web
  file_server
}

http://admin.localhost:8088 {
  redir https://admin.localhost:8443{uri}
}

https://admin.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host admin.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  redir /trace /trace/ 308
  handle_path /trace-api/* {
    reverse_proxy trace-api:3001
  }
  handle_path /trace/* {
    root * /srv/trace-web
    file_server
  }
  handle_path /caddy-logs/* {
    root * /var/log/caddy
    file_server
  }
  root * /srv/admin-web
  file_server
}

http://auth.localhost:8088 {
  redir https://auth.localhost:8443{uri}
}

https://auth.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host auth.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  log_append upstream_host {rp.upstream.host}
  log_append upstream_duration_ms {rp.upstream.duration_ms}
  log_append upstream_latency_ms {rp.upstream.latency_ms}
  reverse_proxy auth-api:3000
}

