{
  log {
    output file /var/log/caddy/access.json {
      roll_size 10MiB
      roll_keep 5
      roll_keep_for 168h
    }
    format json
  }
}

http://home.localhost:8088 {
  redir https://home.localhost:8443{uri}
}

https://home.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host home.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  root * /srv/home-web
  file_server
}

http://appmock.localhost:8088 {
  redir https://appmock.localhost:8443{uri}
}

https://appmock.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host appmock.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  handle_path /trace-api/* {
    request_header Authorization "Bearer change-me-trace-browser-token"
    reverse_proxy trace-api:3001
  }
  handle /api/device/set-password {
    request_header Authorization "Bearer change-me-app-proxy-token"
    reverse_proxy auth-api:3000
  }
  handle /api/* {
    reverse_proxy auth-api:3000
  }
  handle_path /servicemock-api/* {
    reverse_proxy servicemock-api:3002
  }
  root * /srv/appmock-web
  file_server
}

http://admin.localhost:8088 {
  redir https://admin.localhost:8443{uri}
}

https://admin.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host admin.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  redir /trace https://trace.localhost:8443/ 308
  redir /trace/ https://trace.localhost:8443/ 308
  handle_path /trace-api/* {
    request_header Authorization "Bearer change-me-trace-browser-token"
    reverse_proxy trace-api:3001
  }
  handle /api/admin/* {
    request_header Authorization "Bearer change-me-admin-proxy-token"
    reverse_proxy auth-api:3000
  }
  handle /tanmock-api/* {
    uri strip_prefix /tanmock-api
    reverse_proxy tanmock-api:3003
  }
  handle /trace/* {
    redir https://trace.localhost:8443/ 308
  }
  handle_path /caddy-logs/* {
    root * /var/log/caddy
    file_server
  }
  root * /srv/admin-web
  file_server
}

http://auth.localhost:8088 {
  redir https://auth.localhost:8443{uri}
}

https://auth.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host auth.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  log_append upstream_host {rp.upstream.host}
  log_append upstream_duration_ms {rp.upstream.duration_ms}
  log_append upstream_latency_ms {rp.upstream.latency_ms}
  @admin_api path /api/admin/*
  handle @admin_api {
    request_header Authorization "Bearer change-me-admin-proxy-token"
    reverse_proxy auth-api:3000
  }
  @set_password path /api/device/set-password
  handle @set_password {
    request_header Authorization "Bearer change-me-app-proxy-token"
    reverse_proxy auth-api:3000
  }
  reverse_proxy auth-api:3000
}

http://trace.localhost:8088 {
  redir https://trace.localhost:8443{uri}
}

https://trace.localhost:8443 {
  tls /etc/caddy/local-certs/localhost.crt /etc/caddy/local-certs/localhost.key
  log
  log_append host trace.localhost
  log_append correlation_id {http.request.header.X-Correlation-Id}
  log_append trace_id {http.request.header.X-Trace-Id}
  log_append client_name {http.request.header.X-Client-Name}
  log_append method {http.request.method}
  log_append uri {http.request.uri}
  handle_path /trace-api/* {
    request_header Authorization "Bearer change-me-trace-browser-token"
    reverse_proxy trace-api:3001
  }
  @trace_api path /health /traces /traces/* /spans/* /artifacts/* /client-events
  handle @trace_api {
    request_header Authorization "Bearer change-me-trace-browser-token"
    log_append upstream_host {rp.upstream.host}
    log_append upstream_duration_ms {rp.upstream.duration_ms}
    log_append upstream_latency_ms {rp.upstream.latency_ms}
    reverse_proxy trace-api:3001
  }
  handle_path /caddy-logs/* {
    root * /var/log/caddy
    file_server
  }
  root * /srv/trace-web
  file_server
}

